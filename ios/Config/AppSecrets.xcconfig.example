// Copy to AppSecrets.xcconfig for local/TestFlight builds.
// AppSecrets.xcconfig is gitignored; do not commit real keys.
//
// Use a separate iOS-restricted Google Maps Platform key from the web app.
// Restrict it to bundle id au.com.gatherhub and API-restrict it to Places API.

GOOGLE_MAPS_API_KEY = your_ios_google_maps_key_here
