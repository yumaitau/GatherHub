{
  "name": "gatherhub",
  "version": "0.1.0",
  "private": true,
  "description": "GatherHub — a modern operating system for community sports clubs and volunteer-run organisations.",
  "license": "MIT",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspace web",
    "lint": "npm run lint --workspace web",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "convex:dev": "npm run convex:dev --workspace web",
    "seed": "npm run seed --workspace web",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "sonner": "^2.0.7"
  },
  "overrides": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
